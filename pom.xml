<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <groupId>io.github.mfaltan</groupId>
    <artifactId>pg-cache</artifactId>
    <version>0.1.0</version>
    <packaging>pom</packaging>

    <name>pg-cache</name>
    <description>Simple caching library</description>

    <modules>
        <module>pg-cache-core</module>
        <module>pg-cache-example-app</module>
    </modules>

    <properties>
        <!-- Java -->
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>

        <!-- Dependencies -->
        <spring.version>6.1.14</spring.version>
        <jackson.core.version>2.17.2</jackson.core.version>
        <lombok.version>1.18.34</lombok.version>
        <guava.version>33.5.0-jre</guava.version>
        <!-- Test -->
        <junit.version>5.10.2</junit.version>
        <assertj.core.version>3.27.7</assertj.core.version>
        <!-- Plugins -->
        <maven.compiler.plugin.version>3.15.0</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.5.5</maven.surefire.plugin.version>
        <maven.failsafe.plugin.version>3.5.5</maven.failsafe.plugin.version>
    </properties>

    <dependencies>
        <!-- Add dependencies here later -->
    </dependencies>

</project>